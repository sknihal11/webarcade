{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomId": {
        ".read": "auth != null && auth.token.email_verified === true && auth.token.email.matches(/^[A-Za-z0-9._%+-]+@gmail\\.com$/)",
        ".write": "auth != null && auth.token.email_verified === true && auth.token.email.matches(/^[A-Za-z0-9._%+-]+@gmail\\.com$/)"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
