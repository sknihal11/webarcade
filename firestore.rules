rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[A-Za-z0-9._%+-]+@gmail\\.com$');
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isTrustedUser() {
      return isAllowedEmail() && isVerifiedUser();
    }

    function isAdmin() {
      return isVerifiedUser()
        && (
          request.auth.token.email == "nihalsk2022@gmail.com"
          || request.auth.token.email == "support@webarcade.in"
        );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requestedUsernameReserved() {
      return request.resource.data.usernameLower is string
        && exists(/databases/$(database)/documents/usernames/$(request.resource.data.usernameLower))
        && get(/databases/$(database)/documents/usernames/$(request.resource.data.usernameLower)).data.uid == request.auth.uid;
    }

    function usernameUnchanged() {
      return resource != null
        && resource.data.usernameLower == request.resource.data.usernameLower;
    }

    function validParticipantIds(ids) {
      return ids is list && ids.size() >= 1 && ids.size() <= 4;
    }

    function isMatchParticipant() {
      return isSignedIn()
        && (
          resource.data.host == request.auth.uid
          || (
            resource.data.participantIds is list
            && resource.data.participantIds.hasAny([request.auth.uid])
          )
        );
    }

    function isJoiningWaitingRoom() {
      return isSignedIn()
        && resource.data.status == "waiting"
        && request.resource.data.status == "waiting"
        && validParticipantIds(request.resource.data.participantIds)
        && resource.data.participantIds is list
        && request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1
        && request.resource.data.participantIds.hasAll(resource.data.participantIds)
        && request.resource.data.participantIds.hasAny([request.auth.uid]);
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create: if isAllowedEmail()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.usernameLower == usernameLower
        && !exists(/databases/$(database)/documents/usernames/$(usernameLower));
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /users/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && isAllowedEmail()
        && request.resource.data.email == request.auth.token.email
        && requestedUsernameReserved();
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.email == request.auth.token.email
          && (
            usernameUnchanged()
            || requestedUsernameReserved()
          )
        );
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /public_profiles/{userId} {
      allow read: if true;
      allow create, update: if isAdmin() || (isOwner(userId) && isTrustedUser());
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /mail_campaigns/{campaignId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /game_requests/{requestId} {
      allow create: if isTrustedUser()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow read: if isAdmin() || (isTrustedUser() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isTrustedUser();
      allow create: if isTrustedUser()
        && request.resource.data.host == request.auth.uid
        && request.resource.data.status == "waiting"
        && validParticipantIds(request.resource.data.participantIds)
        && request.resource.data.participantIds.size() == 1
        && request.resource.data.participantIds[0] == request.auth.uid;
      allow update: if isAdmin() || (isTrustedUser() && (isMatchParticipant() || isJoiningWaitingRoom()));
      allow delete: if isAdmin() || (isTrustedUser() && isMatchParticipant());
    }

    match /scores_2048/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }

    match /scores_flappy/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }

    match /scores_solitaire/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }

    match /scores_pong/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }

    match /scores_snake/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }

    match /scores_tetris/{userId} {
      allow read: if isTrustedUser();
      allow create, update, delete: if isAdmin() || (isTrustedUser() && isOwner(userId));
    }
  }
}
