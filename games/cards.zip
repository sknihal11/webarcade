             <script>
    $(function() {
        bizx.cmp.ifConsent({ purposes: 'all' , vendors: 'narrative'}, function() {
            var current_time = (new Date()).getTime();
            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3Abb6a3fd1-69a7-4a96-b47a-57f327809f91&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Fvector-cards%2F&id=pagetitle%3AVector+Playing+Cards+download+%7C+SourceForge.net&id=vertical%3AOpen+Source+Software&id=product%3AVector+Playing+Cards&id=topics%3AGraphics%2CLibraries";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
